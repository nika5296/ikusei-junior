# デプロイ済みウェブアプリの exec URL（末尾スラッシュなし）
# 例: https://script.google.com/macros/s/AKfy.../exec
GAS_STUDENT_API_BASE_URL=

# （任意）ロゴ・マスコットのフォールバック用ベース URL（末尾スラッシュなし）。GAS の assets が空のときだけ使われます。
# 公式 PNG を parent-portal/public/brand/ に置く場合の例（ファイル名は lib/student-assets.ts の BRAND_ASSET_FILES と一致）:
# NEXT_PUBLIC_BRAND_ASSET_BASE_URL=/brand
# 外部 CDN の例:
# NEXT_PUBLIC_BRAND_ASSET_BASE_URL=https://example.com/path/to/brand
